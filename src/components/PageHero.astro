---
interface Props {
  eyebrow?: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="bg-navy-950 text-ivory">
  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-14 sm:px-6 md:py-20 lg:grid-cols-[1fr_0.72fr] lg:px-8">
    <div class="max-w-3xl">
      {eyebrow && <p class="text-sm uppercase tracking-[0.32em] text-gold-pale/82">{eyebrow}</p>}
      <h1 class="mt-5 font-serif text-4xl font-semibold leading-tight sm:text-5xl lg:text-6xl">{title}</h1>
      <p class="mt-6 max-w-2xl text-base leading-8 text-ivory/76 sm:text-lg">{description}</p>
    </div>
    <div class="min-h-72 border border-gold-muted/30 bg-navy-900 shadow-soft">
      <div class="grid h-full grid-rows-[1fr_auto]">
        <div class="relative overflow-hidden p-6">
          <div class="absolute inset-x-8 top-8 h-px bg-gold-muted/35"></div>
          <div class="absolute bottom-8 left-8 right-8 h-px bg-gold-muted/35"></div>
          <div class="flex h-full items-center justify-center">
            <div class="aspect-[3/4] w-36 border border-gold-muted/55 bg-ivory p-4 text-center text-navy-950 shadow-soft sm:w-44">
              <div class="flex h-full flex-col justify-between border border-gold-deep/30 p-3">
                <p class="font-serif text-lg font-semibold leading-snug">华夏义民起义、变革、正常化之法理</p>
                <p class="text-xs tracking-[0.24em] text-gold-deep">三卷本</p>
              </div>
            </div>
          </div>
        </div>
        <div class="border-t border-gold-muted/25 px-6 py-4 text-sm leading-6 text-ivory/68">心境科学 · 名实学科 · 群境科学 · 正常化法理</div>
      </div>
    </div>
  </div>
</section>
