---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry?: CollectionEntry<'book'>;
}

const { entry } = Astro.props;
const splitMarker = '\n补记：\n';
const [afterwordText = '', supplementRest = ''] = entry?.body.split(splitMarker) ?? [];
const supplementText = supplementRest ? `补记：\n${supplementRest}` : '';
const toParagraphs = (text: string) => text
  .split(/\n{2,}/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);
const afterwordParagraphs = toParagraphs(afterwordText);
const supplementParagraphs = toParagraphs(supplementText);

const tabs = [
  { id: 'afterword', label: '后记' },
  { id: 'supplement', label: '补记' },
  { id: 'articles', label: '作者最新文章' },
  { id: 'videos', label: '视频资料' }
];

const articleSlots = [
  { title: '作者文章一', date: '待发布', summary: '后续作者文章可在此处按时间顺序添加摘要与阅读全文入口。' },
  { title: '作者文章二', date: '待发布', summary: '文章卡片适合放置标题、日期、摘要与链接。' },
  { title: '作者文章三', date: '待发布', summary: '新增文章后按纵向排列，便于检索和连续阅读。' }
];

const videoSlots = Array.from({ length: 5 }, (_, index) => ({
  title: `视频资料 ${index + 1}`,
  meta: '待发布',
  summary: '可放置章节讲解、访谈、图片资料或云盘链接。'
}));
---

<section class="bg-ivory text-ink" data-afterword-tabs>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="flex flex-wrap gap-2 border-b border-gold-deep/20 pb-3">
      {tabs.map((tab, index) => (
        <button
          class:list={[
            'afterword-tab border border-gold-deep/25 px-4 py-2 text-sm text-gold-deep transition hover:border-navy-850 hover:text-navy-850',
            index === 0 && 'is-active bg-navy-850 text-ivory'
          ]}
          type="button"
          data-afterword-tab={tab.id}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <div class="mt-6">
      <section class="afterword-panel is-active border border-gold-deep/20 bg-white/68 p-5 sm:p-7" data-afterword-panel="afterword">
        {afterwordParagraphs.length ? (
          <div class="academic-prose prose max-w-none">
            {afterwordParagraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        ) : (
          <p class="text-sm leading-7 text-ink/72">后记正文待补充。</p>
        )}
      </section>

      <section class="afterword-panel hidden border border-gold-deep/20 bg-white/68 p-5 sm:p-7" data-afterword-panel="supplement">
        <div class="academic-prose prose max-w-none">
          {supplementParagraphs.length ? (
            supplementParagraphs.map((paragraph) => <p>{paragraph}</p>)
          ) : (
            <p>补记正文待补充。</p>
          )}
        </div>
      </section>

      <section class="afterword-panel hidden border border-gold-deep/20 bg-white/68 p-5 sm:p-7" data-afterword-panel="articles">
        <div class="grid gap-4">
          {articleSlots.map((article) => (
            <article class="border border-gold-deep/15 bg-ivory p-4">
              <p class="font-latin text-xs uppercase tracking-[0.22em] text-gold-deep">{article.date}</p>
              <h3 class="mt-2 font-serif text-xl font-semibold text-navy-850">{article.title}</h3>
              <p class="mt-2 text-sm leading-7 text-ink/72">{article.summary}</p>
              <a class="mt-3 inline-flex text-sm font-medium text-gold-deep hover:text-navy-850" href="#">阅读全文</a>
            </article>
          ))}
        </div>
      </section>

      <section class="afterword-panel hidden border border-gold-deep/20 bg-white/68 p-5 sm:p-7" data-afterword-panel="videos">
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {videoSlots.map((video) => (
            <article class="border border-gold-deep/15 bg-ivory p-4">
              <div class="aspect-video border border-gold-deep/20 bg-white/70"></div>
              <p class="mt-3 font-latin text-xs uppercase tracking-[0.22em] text-gold-deep">{video.meta}</p>
              <h3 class="mt-2 font-serif text-lg font-semibold text-navy-850">{video.title}</h3>
              <p class="mt-2 text-sm leading-7 text-ink/72">{video.summary}</p>
            </article>
          ))}
        </div>
      </section>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-afterword-tab]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!(button instanceof HTMLElement)) return;
      const target = button.dataset.afterwordTab;
      document.querySelectorAll('[data-afterword-tab]').forEach((tab) => {
        const active = tab instanceof HTMLElement && tab.dataset.afterwordTab === target;
        tab.classList.toggle('is-active', active);
        tab.classList.toggle('bg-navy-850', active);
        tab.classList.toggle('text-ivory', active);
        tab.classList.toggle('text-gold-deep', !active);
      });
      document.querySelectorAll('[data-afterword-panel]').forEach((panel) => {
        const active = panel instanceof HTMLElement && panel.dataset.afterwordPanel === target;
        panel.classList.toggle('hidden', !active);
        panel.classList.toggle('is-active', active);
      });
      window.applyTraditional?.();
    });
  });
</script>
