---
const panels = [
  {
    title: '后记',
    text: '二零一八年九月五日写于山东省潍坊市。此书，献给我至亲至爱之父母，荣誉归于您们。',
    type: '正文'
  },
  {
    title: '补记',
    text: '二零二零年四月二十日凌晨二点四十分于家宅；二零二零年十二月五日午十一点三十分及前增补于家宅。',
    type: '增补'
  },
  {
    title: '作者最新文章',
    text: '后续文章按标题、日期、摘要、阅读全文入口纵向排列，适合持续更新。',
    type: '文章'
  },
  {
    title: '视频资料',
    text: '章节讲解、访谈和公开视频可按卡片陈列；五个以上自动换行，保留标题、日期与说明。',
    type: '视频'
  }
];
---

<section class="bg-ivory text-ink">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="grid gap-4 md:grid-cols-2">
      {panels.map((panel) => (
        <article class="border border-gold-deep/20 bg-white/68 p-5">
          <p class="font-latin text-xs uppercase tracking-[0.24em] text-gold-deep">{panel.type}</p>
          <h2 class="mt-3 font-serif text-2xl text-navy-850">{panel.title}</h2>
          <p class="mt-3 text-sm leading-7 text-ink/72">{panel.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
