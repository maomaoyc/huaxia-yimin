---
interface Props {
  mode: 'author' | 'reader';
}

const { mode } = Astro.props;
const contact = 'yc114de@gmail.com';
const isAuthor = mode === 'author';
const title = isAuthor ? '作者资料上传入口' : '读者留言与反馈';
const intro = isAuthor
  ? '用于提交章节讲解视频、图片、校订资料或补充说明。静态网站不直接保存上传文件，请通过邮件发送附件，或提交云盘链接。'
  : '用于读者留言、错字反馈、章节建议、出版合作线索或阅读意见。';
---

<section class="bg-ivory text-ink">
  <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="border border-gold-deep/20 bg-white/70 p-5 sm:p-7">
      <h2 class="font-serif text-2xl font-semibold text-navy-850">{title}</h2>
      <p class="mt-3 text-sm leading-7 text-ink/72">{intro}</p>
      <p class="mt-2 text-sm leading-7 text-ink/72">出版、授权、校订与资料提交联系：<a class="text-gold-deep underline decoration-gold-deep/30" href={`mailto:${contact}`}>{contact}</a></p>

      <form class="mt-6 grid gap-4" data-contact-form data-mode={mode} data-contact={contact}>
        <label class="grid gap-2 text-sm">
          <span class="font-medium text-navy-850">姓名 / 称呼</span>
          <input class="border border-gold-deep/25 bg-ivory px-3 py-2 text-ink outline-none focus:border-gold-deep" name="name" type="text" />
        </label>
        <label class="grid gap-2 text-sm">
          <span class="font-medium text-navy-850">联系方式</span>
          <input class="border border-gold-deep/25 bg-ivory px-3 py-2 text-ink outline-none focus:border-gold-deep" name="contactInfo" type="text" />
        </label>
        {isAuthor && (
          <label class="grid gap-2 text-sm">
            <span class="font-medium text-navy-850">资料链接 / 附件说明</span>
            <input class="border border-gold-deep/25 bg-ivory px-3 py-2 text-ink outline-none focus:border-gold-deep" name="resourceLink" type="text" placeholder="视频、图片或云盘链接" />
          </label>
        )}
        <label class="grid gap-2 text-sm">
          <span class="font-medium text-navy-850">{isAuthor ? '资料说明' : '留言内容'}</span>
          <textarea class="min-h-40 border border-gold-deep/25 bg-ivory px-3 py-2 text-ink outline-none focus:border-gold-deep" name="message"></textarea>
        </label>
        <div class="flex flex-wrap gap-3">
          <button class="border border-gold-deep/35 px-4 py-2 text-sm font-medium text-gold-deep transition hover:border-navy-850 hover:text-navy-850" type="submit">生成邮件</button>
          <a class="border border-gold-deep/20 px-4 py-2 text-sm text-ink/60 transition hover:border-gold-deep/45 hover:text-gold-deep" href={`mailto:${contact}`}>直接写邮件</a>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-contact-form]').forEach((form) => {
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const target = event.currentTarget;
      if (!(target instanceof HTMLFormElement)) return;
      const data = new FormData(target);
      const mode = target.dataset.mode === 'author' ? '作者资料提交' : '读者留言反馈';
      const contact = target.dataset.contact || 'yc114de@gmail.com';
      const lines = [
        `类别：${mode}`,
        `姓名：${data.get('name') || ''}`,
        `联系方式：${data.get('contactInfo') || ''}`,
        `资料链接：${data.get('resourceLink') || ''}`,
        '',
        `${data.get('message') || ''}`
      ];
      const subject = encodeURIComponent(`《华夏义民起义、变革、正常化之法理》${mode}`);
      const body = encodeURIComponent(lines.join('\n'));
      window.location.href = `mailto:${contact}?subject=${subject}&body=${body}`;
    });
  });
</script>
