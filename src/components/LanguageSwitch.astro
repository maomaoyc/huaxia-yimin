  };
  const convertText = (value) => {
    let output = value || '';
    phraseMap.forEach(([from, to]) => {
      output = output.split(from).join(to);
    });
    return output.split('').map((char) => traditionalMap[char] || char).join('');
  };
  const convertNode = (node) => {
    if (node.nodeType === Node.TEXT_NODE) {
      node.nodeValue = convertText(node.nodeValue || '');
      return;
    }
    if (node instanceof HTMLElement && ['SCRIPT', 'STYLE'].includes(node.tagName)) return;
    if (node instanceof HTMLElement) {
      ['placeholder', 'title', 'aria-label', 'value'].forEach((attribute) => {
        const value = node.getAttribute(attribute);
        if (value) node.setAttribute(attribute, convertText(value));
      });
      if (['TEXTAREA', 'INPUT'].includes(node.tagName)) return;
    }
    node.childNodes.forEach(convertNode);
  };
  const applyTraditional = () => {
    if (document.documentElement.dataset.scriptMode === 'traditional') return;
    document.documentElement.lang = 'zh-Hant';
    document.documentElement.dataset.scriptMode = 'traditional';
    convertNode(document.body);
  };
  (window as any).toTraditionalText = convertText;
  (window as any).applyTraditional = () => {
    document.documentElement.dataset.scriptMode = '';
    applyTraditional();
  };
  if (localStorage.getItem('han-script') === 'traditional') applyTraditional();
  document.querySelector('[data-simplified-toggle]')?.addEventListener('click', () => {
    localStorage.setItem('han-script', 'simplified');
  });
  document.querySelector('[data-traditional-toggle]')?.addEventListener('click', () => {
    localStorage.setItem('han-script', 'traditional');
    document.documentElement.dataset.scriptMode = '';
    applyTraditional();
  });
</script>
