---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'book'>;
  title?: string;
}

const { entry, title = entry.data.title } = Astro.props;
const { Content } = await entry.render();
---

<section class="bg-ivory text-ink">
  <div class="mx-auto max-w-5xl px-4 pb-12 sm:px-6 lg:px-8">
    <article class="reading-article border border-gold-deep/20 bg-white/78 px-5 py-7 shadow-sm sm:px-8 lg:px-10">
      <p class="text-xs uppercase tracking-[0.24em] text-gold-deep">Original Text</p>
      <h2 class="mt-3 font-serif text-3xl font-semibold text-navy-850">{title}</h2>
      <div class="academic-prose prose prose-lg mt-6 max-w-none">
        <Content />
      </div>
    </article>
  </div>
</section>
