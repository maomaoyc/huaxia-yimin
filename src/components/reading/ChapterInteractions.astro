---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '@/lib/i18n';

interface Props {
  entry: CollectionEntry<'book'>;
  locale?: Locale;
}

const { entry, locale = 'zh' } = Astro.props;
const copy = {
  zh: {
    title: '章节批注与评论',
    intro: '可选中正文后记录划线与想法，也可留下本章评论。未注册也可以评论；注册信息不写入 GitHub。',
    register: '读者注册',
    name: '姓名 / 昵称',
    contact: '联系方式',
    note: '注册说明',
    registerButton: '提交注册',
    annotation: '选中文本批注',
    selected: '选中文本',
    idea: '想法',
    saveAnnotation: '保存批注',
    comment: '章节评论',
    commentBody: '评论内容',
    saveComment: '发布到本机评论区',
    publishComment: '发表评论',
    empty: '暂无本机评论。',
    localOnly: '已预留 Cloudflare 评论存储；未配置时评论先保存在本机浏览器。'
  },
  en: {
    title: 'Chapter Notes and Comments',
    intro: 'Select text to save a highlight and note, or leave a chapter comment. Registration is optional; registration data is not written to GitHub.',
    register: 'Reader Registration',
    name: 'Name / Nickname',
    contact: 'Contact',
    note: 'Registration Note',
    registerButton: 'Submit Registration',
    annotation: 'Selected Text Note',
    selected: 'Selected Text',
    idea: 'Idea',
    saveAnnotation: 'Save Note',
    comment: 'Chapter Comment',
    commentBody: 'Comment',
    saveComment: 'Post Locally',
    publishComment: 'Post Comment',
    empty: 'No local comments yet.',
    localOnly: 'Cloudflare comment storage is supported; when it is not configured, comments stay in this browser.'
  },
  es: {
    title: 'Notas y comentarios del capítulo',
    intro: 'Seleccione texto para guardar una marca y una nota, o deje un comentario del capítulo. El registro es opcional; los datos no se escriben en GitHub.',
    register: 'Registro de lector',
    name: 'Nombre / apodo',
    contact: 'Contacto',
    note: 'Nota de registro',
    registerButton: 'Enviar registro',
    annotation: 'Nota sobre texto seleccionado',
    selected: 'Texto seleccionado',
    idea: 'Idea',
    saveAnnotation: 'Guardar nota',
    comment: 'Comentario del capítulo',
    commentBody: 'Comentario',
    saveComment: 'Publicar localmente',
    publishComment: 'Publicar comentario',
    empty: 'Aún no hay comentarios locales.',
    localOnly: 'El almacenamiento de comentarios de Cloudflare está preparado; si no está configurado, los comentarios quedan en este navegador.'
  }
};
const text = copy[locale];
---

<section class="mt-7 border border-gold-deep/20 bg-white/72 p-5 sm:p-6" data-chapter-interactions data-chapter={entry.slug}>
  <div class="grid gap-3 sm:grid-cols-[1fr_auto] sm:items-start">
    <div>
      <h2 class="font-serif text-2xl font-semibold text-navy-850">{text.title}</h2>
      <p class="mt-2 text-sm leading-7 text-ink/70">{text.intro}</p>
      <p class="mt-1 text-xs leading-5 text-ink/55">{text.localOnly}</p>
    </div>
    <button class="w-fit border border-gold-deep/35 px-4 py-2 text-sm text-gold-deep transition hover:border-navy-850 hover:text-navy-850" type="button" data-open-register>{text.register}</button>
  </div>

  <div class="mt-6 grid gap-5 lg:grid-cols-2">
    <form class="grid gap-3 border border-gold-deep/15 bg-ivory p-4" data-annotation-form>
      <h3 class="font-serif text-xl text-navy-850">{text.annotation}</h3>
      <label class="grid gap-2 text-sm">
        <span class="font-medium text-navy-850">{text.selected}</span>
        <textarea class="min-h-24 border border-gold-deep/25 bg-white px-3 py-2 text-ink outline-none focus:border-gold-deep" name="selectedText" data-selected-text></textarea>
      </label>
      <label class="grid gap-2 text-sm">
        <span class="font-medium text-navy-850">{text.idea}</span>
        <textarea class="min-h-24 border border-gold-deep/25 bg-white px-3 py-2 text-ink outline-none focus:border-gold-deep" name="idea"></textarea>
      </label>
      <button class="w-fit border border-gold-deep/35 px-4 py-2 text-sm text-gold-deep" type="submit">{text.saveAnnotation}</button>
    </form>

    <form class="grid gap-3 border border-gold-deep/15 bg-ivory p-4" data-comment-form>
      <h3 class="font-serif text-xl text-navy-850">{text.comment}</h3>
      <div class="grid gap-3 sm:grid-cols-2">
        <label class="grid gap-2 text-sm">
          <span class="font-medium text-navy-850">{text.name}</span>
          <input class="border border-gold-deep/25 bg-white px-3 py-2 text-ink outline-none focus:border-gold-deep" name="name" type="text" />
        </label>
        <label class="grid gap-2 text-sm">
          <span class="font-medium text-navy-850">{text.contact}</span>
          <input class="border border-gold-deep/25 bg-white px-3 py-2 text-ink outline-none focus:border-gold-deep" name="contact" type="text" />
        </label>
      </div>
      <label class="grid gap-2 text-sm">
        <span class="font-medium text-navy-850">{text.commentBody}</span>
        <textarea class="min-h-28 border border-gold-deep/25 bg-white px-3 py-2 text-ink outline-none focus:border-gold-deep" name="comment" required></textarea>
      </label>
      <button class="w-fit border border-gold-deep/35 px-4 py-2 text-sm text-gold-deep" type="submit">{text.publishComment}</button>
    </form>
  </div>

  <div class="mt-5 grid gap-3" data-comment-list>
    <p class="text-sm text-ink/55" data-empty-comments>{text.empty}</p>
  </div>
</section>

<dialog class="w-[min(92vw,34rem)] border border-gold-deep/35 bg-ivory p-0 text-ink shadow-soft" data-register-dialog>
  <div class="flex items-center justify-between border-b border-gold-deep/20 px-5 py-4">
    <h2 class="font-serif text-2xl text-navy-850">{text.register}</h2>
    <button class="border border-gold-deep/35 px-3 py-1.5 text-sm text-gold-deep" type="button" data-close-register>关闭</button>
  </div>
  <form class="grid gap-4 p-5" data-register-form>
    <label class="grid gap-2 text-sm">
      <span class="font-medium text-navy-850">{text.name}</span>
      <input class="border border-gold-deep/25 bg-white px-3 py-2 text-ink outline-none focus:border-gold-deep" name="name" type="text" required />
    </label>
    <label class="grid gap-2 text-sm">
      <span class="font-medium text-navy-850">{text.contact}</span>
      <input class="border border-gold-deep/25 bg-white px-3 py-2 text-ink outline-none focus:border-gold-deep" name="contact" type="text" required />
    </label>
    <label class="grid gap-2 text-sm">
      <span class="font-medium text-navy-850">{text.note}</span>
      <textarea class="min-h-28 border border-gold-deep/25 bg-white px-3 py-2 text-ink outline-none focus:border-gold-deep" name="note"></textarea>
    </label>
    <div class="flex flex-wrap items-center gap-3">
      <button class="border border-gold-deep/35 px-4 py-2 text-sm text-gold-deep" type="submit">{text.registerButton}</button>
      <p class="text-sm text-ink/60" data-register-status></p>
    </div>
  </form>
</dialog>

<script>
  const interactions = document.querySelector('[data-chapter-interactions]');
  const chapter = interactions instanceof HTMLElement ? interactions.dataset.chapter || 'chapter' : 'chapter';
  const commentKey = `huaxia-comments:${chapter}`;
  const annotationKey = `huaxia-annotations:${chapter}`;
  const selectedText = document.querySelector('[data-selected-text]');
  let remoteComments = [];

  document.addEventListener('selectionchange', () => {
    const value = window.getSelection()?.toString().trim() || '';
    if (value && selectedText instanceof HTMLTextAreaElement) selectedText.value = value.slice(0, 1200);
  });

  const renderComments = () => {
    const list = document.querySelector('[data-comment-list]');
    if (!list) return;
    const localComments = JSON.parse(localStorage.getItem(commentKey) || '[]');
    const comments = remoteComments.length ? remoteComments : localComments;
    list.querySelectorAll('[data-local-comment]').forEach((item) => item.remove());
    const empty = list.querySelector('[data-empty-comments]');
    if (empty instanceof HTMLElement) empty.style.display = comments.length ? 'none' : '';
    comments.forEach((comment) => {
      const article = document.createElement('article');
      article.dataset.localComment = 'true';
      article.className = 'border border-gold-deep/15 bg-ivory p-4 text-sm leading-7 text-ink/74';
      article.innerHTML = `<p class="font-medium text-navy-850"></p><p class="mt-1"></p><p class="mt-2 text-xs text-ink/45"></p>`;
      article.children[0].textContent = comment.name || '读者';
      article.children[1].textContent = comment.comment || '';
      article.children[2].textContent = comment.createdAt ? new Date(comment.createdAt).toLocaleString() : '';
      list.appendChild(article);
    });
  };

  const loadRemoteComments = async () => {
    try {
      const response = await fetch(`/api/comments?chapter=${encodeURIComponent(chapter)}`);
      if (!response.ok) throw new Error('comments unavailable');
      const payload = await response.json();
      if (Array.isArray(payload.comments)) {
        remoteComments = payload.comments;
        renderComments();
      }
    } catch {
      renderComments();
    }
  };

  document.querySelector('[data-annotation-form]')?.addEventListener('submit', (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    if (!(form instanceof HTMLFormElement)) return;
    const data = new FormData(form);
    const annotations = JSON.parse(localStorage.getItem(annotationKey) || '[]');
    annotations.unshift({
      selectedText: data.get('selectedText') || '',
      idea: data.get('idea') || '',
      createdAt: new Date().toLocaleString()
    });
    localStorage.setItem(annotationKey, JSON.stringify(annotations.slice(0, 50)));
    form.reset();
  });

  document.querySelector('[data-comment-form]')?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    if (!(form instanceof HTMLFormElement)) return;
    const data = new FormData(form);
    const nextComment = {
      name: data.get('name') || '',
      contact: data.get('contact') || '',
      comment: data.get('comment') || '',
      createdAt: new Date().toLocaleString()
    };
    let savedRemote = false;
    try {
      data.set('chapter', chapter);
      const response = await fetch('/api/comments', { method: 'POST', body: data });
      if (response.ok) {
        const payload = await response.json();
        if (payload.comment) {
          remoteComments.unshift(payload.comment);
          savedRemote = true;
        }
      }
    } catch {}
    const comments = JSON.parse(localStorage.getItem(commentKey) || '[]');
    comments.unshift(nextComment);
    localStorage.setItem(commentKey, JSON.stringify(comments.slice(0, 100)));
    if (!savedRemote) remoteComments = [];
    form.reset();
    renderComments();
  });

  const registerDialog = document.querySelector('[data-register-dialog]');
  document.querySelector('[data-open-register]')?.addEventListener('click', () => {
    if (registerDialog instanceof HTMLDialogElement) registerDialog.showModal();
  });
  document.querySelector('[data-close-register]')?.addEventListener('click', () => {
    if (registerDialog instanceof HTMLDialogElement) registerDialog.close();
  });
  document.querySelector('[data-register-form]')?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    if (!(form instanceof HTMLFormElement)) return;
    const status = document.querySelector('[data-register-status]');
    if (status) status.textContent = '提交中...';
    const data = new FormData(form);
    try {
      const response = await fetch('/api/register', { method: 'POST', body: data });
      if (!response.ok) throw new Error('request failed');
      if (status) status.textContent = '已提交。';
      form.reset();
    } catch {
      const subject = encodeURIComponent('读者注册');
      const body = encodeURIComponent(`姓名：${data.get('name') || ''}\n联系方式：${data.get('contact') || ''}\n说明：${data.get('note') || ''}`);
      window.location.href = `mailto:yc114de@gmail.com?subject=${subject}&body=${body}`;
    }
  });

  loadRemoteComments();
</script>
