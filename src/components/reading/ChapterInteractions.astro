---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '@/lib/i18n';

interface Props {
  entry: CollectionEntry<'book'>;
  locale?: Locale;
}

const { entry, locale = 'zh' } = Astro.props;
const copy = {
  zh: {
    highlight: '高亮',
    underline: '划线',
    idea: '想法',
    note: '想法',
    save: '保存',
    cancel: '取消',
    placeholder: '写下想法…',
    defaultName: '读者'
  },
  en: {
    highlight: 'Highlight',
    underline: 'Underline',
    idea: 'Note',
    note: 'Note',
    save: 'Save',
    cancel: 'Cancel',
    placeholder: 'Add a note...',
    defaultName: 'Reader'
  },
  es: {
    highlight: 'Resaltar',
    underline: 'Subrayar',
    idea: 'Nota',
    note: 'Nota',
    save: 'Guardar',
    cancel: 'Cancelar',
    placeholder: 'Escribir nota...',
    defaultName: 'Lector'
  }
};
const text = copy[locale];
---

<div class="selection-tools" data-selection-tools data-chapter={entry.slug}>
  <button type="button" data-mark="highlight">{text.highlight}</button>
  <button type="button" data-mark="underline">{text.underline}</button>
  <button type="button" data-mark="idea">{text.idea}</button>
</div>

<form class="idea-popover grid gap-2" data-idea-popover>
  <label>
    <span>{text.note}</span>
    <textarea name="note" rows="2" placeholder={text.placeholder} required></textarea>
  </label>
  <div class="flex gap-2">
    <button class="border border-gold-deep/35 px-3 py-1.5 text-sm text-gold-deep" type="submit">{text.save}</button>
    <button class="border border-gold-deep/20 px-3 py-1.5 text-sm text-ink/65" type="button" data-idea-cancel>{text.cancel}</button>
  </div>
</form>

<script define:vars={{ defaultName: text.defaultName }}>
  const tools = document.querySelector('[data-selection-tools]');
  const chapter = tools instanceof HTMLElement ? tools.dataset.chapter || 'chapter' : 'chapter';
  const article = document.querySelector('.reading-article');
  const ideaPopover = document.querySelector('[data-idea-popover]');
  let activeRange = null;
  let activeNoteTarget = null;
  let activeMarkTarget = null;

  const markKey = `huaxia-reader-marks:${chapter}`;

  const hideTools = () => {
    if (tools instanceof HTMLElement) tools.style.display = 'none';
  };

  const hideIdea = () => {
    if (ideaPopover instanceof HTMLElement) ideaPopover.style.display = 'none';
  };

  const placeElementNearRange = (element, range, offsetY = 10) => {
    const rect = range.getBoundingClientRect();
    const popoverWidth = 260;
    const popoverHeight = 170;
    const left = Math.min(window.innerWidth - popoverWidth - 12, Math.max(12, rect.left));
    const bottomTop = rect.bottom + offsetY;
    const top = bottomTop + popoverHeight > window.innerHeight
      ? Math.max(12, rect.top - popoverHeight - offsetY)
      : Math.max(12, bottomTop);
    element.style.left = `${left}px`;
    element.style.top = `${top}px`;
  };

  const readStoredMarks = () => {
    try {
      return JSON.parse(localStorage.getItem(markKey) || '[]');
    } catch {
      return [];
    }
  };

  const writeStoredMarks = (marks) => {
    localStorage.setItem(markKey, JSON.stringify(marks.slice(0, 300)));
  };

  const getMarkElement = (node) => {
    if (!node) return null;
    const element = node.nodeType === Node.TEXT_NODE ? node.parentElement : node;
    return element instanceof HTMLElement ? element.closest('.reader-mark') : null;
  };

  const syncStoredMark = (target) => {
    if (!(target instanceof HTMLElement)) return;
    const id = target.dataset.markId;
    if (!id) return;
    const marks = readStoredMarks();
    const index = marks.findIndex((item) => item.id === id);
    const next = {
      id,
      type: target.dataset.markType || 'highlight',
      selected: target.dataset.selectedText || target.textContent?.replace(/\d+$/, '').trim() || '',
      notes: JSON.parse(target.dataset.notes || '[]'),
      createdAt: target.dataset.createdAt || new Date().toLocaleString('zh-CN', { hour12: false })
    };
    if (index >= 0) marks[index] = next;
    else marks.unshift(next);
    writeStoredMarks(marks);
  };

  const unwrapMark = (target) => {
    if (!(target instanceof HTMLElement)) return;
    const id = target.dataset.markId;
    if (id) writeStoredMarks(readStoredMarks().filter((item) => item.id !== id));
    target.querySelector('.reader-note-anchor')?.remove();
    target.querySelector('.reader-note-badge')?.remove();
    target.querySelector('.reader-note-tooltip')?.remove();
    const parent = target.parentNode;
    if (!parent) return;
    while (target.firstChild) parent.insertBefore(target.firstChild, target);
    target.remove();
    parent.normalize();
  };

  const assignMarkData = (wrapper, type, selected, notes = []) => {
    wrapper.classList.add('reader-mark');
    wrapper.dataset.markId = wrapper.dataset.markId || `mark-${Date.now()}-${Math.random().toString(36).slice(2, 8)}`;
    wrapper.dataset.markType = type;
    wrapper.dataset.selectedText = selected;
    wrapper.dataset.createdAt = wrapper.dataset.createdAt || new Date().toLocaleString('zh-CN', { hour12: false });
    wrapper.dataset.notes = JSON.stringify(notes);
    wrapper.classList.toggle('reader-highlight', type === 'highlight');
    wrapper.classList.toggle('reader-underline', type === 'underline');
    wrapper.classList.toggle('reader-note', type === 'note');
  };

  const wrapRange = (type) => {
    if (!activeRange) return null;
    const wrapper = document.createElement('span');
    const selected = activeRange.toString().trim();
    assignMarkData(wrapper, type, selected);
    try {
      activeRange.surroundContents(wrapper);
    } catch {
      const contents = activeRange.extractContents();
      wrapper.appendChild(contents);
      activeRange.insertNode(wrapper);
    }
    return wrapper;
  };

  const getExistingNoteTarget = () => {
    const selection = window.getSelection();
    const node = selection?.anchorNode;
    const mark = getMarkElement(node);
    return mark instanceof HTMLElement && mark.dataset.markType === 'note' ? mark : null;
  };

  const renderNoteBadge = (target, notes) => {
    target.querySelector('.reader-note-anchor')?.remove();
    target.querySelector('.reader-note-badge')?.remove();
    target.querySelector('.reader-note-tooltip')?.remove();

    const anchor = document.createElement('span');
    anchor.className = 'reader-note-anchor';
    const badge = document.createElement('sup');
    badge.className = 'reader-note-badge';
    badge.textContent = String(notes.length);

    const tooltip = document.createElement('span');
    tooltip.className = 'reader-note-tooltip';
    notes.forEach((note, index) => {
      const item = document.createElement('span');
      item.className = 'reader-note-item';
      item.textContent = `${note.createdAt}：${note.text}`;
      const del = document.createElement('button');
      del.type = 'button';
      del.dataset.noteDelete = String(index);
      del.textContent = '删除';
      item.appendChild(del);
      tooltip.appendChild(item);
    });
    anchor.append(badge, tooltip);
    target.append(anchor);
  };

  const addNote = (text) => {
    let target = activeNoteTarget;
    if (!target) target = wrapRange('note');
    if (!(target instanceof HTMLElement)) return;
    target.dataset.markType = 'note';
    target.classList.remove('reader-highlight', 'reader-underline');
    target.classList.add('reader-note', 'reader-mark');
    const notes = JSON.parse(target.dataset.notes || '[]');
    const createdAt = new Date().toLocaleString('zh-CN', { hour12: false });
    notes.push({ text, createdAt });
    target.dataset.notes = JSON.stringify(notes);
    renderNoteBadge(target, notes);
    syncStoredMark(target);
  };

  const findTextNode = (selected) => {
    if (!article || !selected) return null;
    const walker = document.createTreeWalker(article, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const parent = node.parentElement;
        if (!parent || parent.closest('.reader-mark')) return NodeFilter.FILTER_REJECT;
        return node.nodeValue?.includes(selected) ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_SKIP;
      }
    });
    return walker.nextNode();
  };

  const restoreMark = (record) => {
    const textNode = findTextNode(record.selected);
    if (!textNode || !textNode.nodeValue) return;
    const start = textNode.nodeValue.indexOf(record.selected);
    if (start < 0) return;
    const range = document.createRange();
    range.setStart(textNode, start);
    range.setEnd(textNode, start + record.selected.length);
    const wrapper = document.createElement('span');
    assignMarkData(wrapper, record.type, record.selected, record.notes || []);
    wrapper.dataset.markId = record.id;
    wrapper.dataset.createdAt = record.createdAt || wrapper.dataset.createdAt || '';
    try {
      range.surroundContents(wrapper);
    } catch {
      return;
    }
    if (record.type === 'note') renderNoteBadge(wrapper, record.notes || []);
  };

  readStoredMarks().slice().reverse().forEach(restoreMark);

  document.addEventListener('mouseup', () => {
    const selection = window.getSelection();
    if (!selection || selection.isCollapsed || !article?.contains(selection.anchorNode)) {
      hideTools();
      return;
    }
    activeRange = selection.getRangeAt(0).cloneRange();
    activeNoteTarget = getExistingNoteTarget();
    activeMarkTarget = getMarkElement(selection.anchorNode);
    const rect = activeRange.getBoundingClientRect();
    if (tools instanceof HTMLElement) {
      tools.style.left = `${Math.min(window.innerWidth - 220, Math.max(12, rect.left))}px`;
      tools.style.top = `${Math.max(12, rect.top - 48)}px`;
      tools.style.display = 'flex';
    }
    hideIdea();
  });

  tools?.querySelectorAll('[data-mark]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!activeRange) return;
      const type = button instanceof HTMLElement ? button.dataset.mark : 'highlight';
      const selected = activeRange.toString();
      if (!selected.trim()) return;
      if (type === 'idea') {
        if (ideaPopover instanceof HTMLElement) {
          placeElementNearRange(ideaPopover, activeRange, 8);
          ideaPopover.style.display = 'grid';
          ideaPopover.querySelector('textarea')?.focus();
        }
      } else {
        if (activeMarkTarget instanceof HTMLElement && activeMarkTarget.dataset.markType === type) {
          unwrapMark(activeMarkTarget);
        } else if (activeMarkTarget instanceof HTMLElement) {
          assignMarkData(activeMarkTarget, type, activeMarkTarget.dataset.selectedText || selected);
          activeMarkTarget.querySelector('.reader-note-anchor')?.remove();
          activeMarkTarget.querySelector('.reader-note-badge')?.remove();
          activeMarkTarget.querySelector('.reader-note-tooltip')?.remove();
          syncStoredMark(activeMarkTarget);
        } else {
          const mark = wrapRange(type === 'underline' ? 'underline' : 'highlight');
          if (mark instanceof HTMLElement) syncStoredMark(mark);
        }
        window.getSelection()?.removeAllRanges();
      }
      hideTools();
    });
  });

  ideaPopover?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!(ideaPopover instanceof HTMLFormElement)) return;
    const data = new FormData(ideaPopover);
    const note = String(data.get('note') || '').trim();
    if (!note) return;
    addNote(note);
    ideaPopover.reset();
    hideIdea();
    window.getSelection()?.removeAllRanges();
  });

  document.querySelector('[data-idea-cancel]')?.addEventListener('click', () => {
    hideIdea();
    window.getSelection()?.removeAllRanges();
  });

  article?.addEventListener('click', (event) => {
    const deleteButton = event.target instanceof HTMLElement ? event.target.closest('[data-note-delete]') : null;
    if (deleteButton instanceof HTMLElement) {
      const mark = deleteButton.closest('.reader-note');
      if (!(mark instanceof HTMLElement)) return;
      const notes = JSON.parse(mark.dataset.notes || '[]');
      notes.splice(Number(deleteButton.dataset.noteDelete || 0), 1);
      mark.dataset.notes = JSON.stringify(notes);
      if (notes.length) {
        renderNoteBadge(mark, notes);
        syncStoredMark(mark);
      } else {
        unwrapMark(mark);
      }
    }
  });
</script>
