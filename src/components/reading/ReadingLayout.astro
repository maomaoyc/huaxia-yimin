---
import type { CollectionEntry } from 'astro:content';
import DownloadButtons from '@/components/DownloadButtons.astro';
import { sortBookEntries } from '@/lib/book';
import { withBase } from '@/lib/paths';

interface Props {
  entry: CollectionEntry<'book'>;
  entries: CollectionEntry<'book'>[];
  previous?: CollectionEntry<'book'>;
  next?: CollectionEntry<'book'>;
}

const { entry, entries, previous, next } = Astro.props;
const { Content } = await entry.render();
const toc = sortBookEntries(entries);
---

<div class="reading-page min-h-screen bg-ivory text-ink" data-reading-page>
  <div class="fixed left-0 right-0 top-0 z-40 h-1 bg-navy-950/10">
    <div class="h-full w-0 bg-gold-deep" data-reading-progress></div>
  </div>

  <section class="bg-navy-950 text-ivory">
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-3xl">
          <p class="text-sm tracking-[0.28em] text-gold-pale/80">{entry.data.volume}</p>
          <h1 class="mt-4 font-serif text-3xl font-semibold leading-tight sm:text-5xl">{entry.data.title}</h1>
          <p class="mt-5 text-base leading-8 text-ivory/76">{entry.data.summary}</p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-3">
          <button type="button" class="border border-gold-muted/55 px-3 py-2 text-sm text-gold-pale transition hover:bg-gold-muted hover:text-navy-950" data-reading-mode>深色阅读</button>
          <DownloadButtons compact />
        </div>
      </div>
    </div>
  </section>

  <div class="mx-auto grid max-w-7xl gap-8 px-4 py-8 sm:px-6 lg:grid-cols-[17rem_1fr] lg:px-8">
    <aside class="lg:sticky lg:top-5 lg:h-[calc(100vh-2.5rem)] lg:overflow-y-auto">
      <details class="border border-gold-deep/20 bg-white/72 p-4 lg:hidden">
        <summary class="cursor-pointer font-serif text-lg text-navy-850">目录</summary>
        <nav class="mt-4 grid gap-2 text-sm">
          {toc.map((item) => (
            <a class:list={['leading-6 text-ink/72 hover:text-gold-deep', item.slug === entry.slug && 'font-medium text-gold-deep']} href={withBase(`/book/${item.slug}/`)}>
              {item.data.chapterNumber === 0 ? item.data.title : `${item.data.volume.replace('原理概论', '')} · ${item.data.title}`}
            </a>
          ))}
        </nav>
      </details>

      <nav class="hidden border border-gold-deep/20 bg-white/72 p-4 lg:block" aria-label="在线阅读目录">
        <p class="font-serif text-xl text-navy-850">目录</p>
        <div class="mt-4 grid gap-2 text-sm">
          {toc.map((item) => (
            <a class:list={['leading-6 text-ink/70 hover:text-gold-deep', item.slug === entry.slug && 'font-medium text-gold-deep']} href={withBase(`/book/${item.slug}/`)}>
              {item.data.chapterNumber === 0 ? item.data.title : `${item.data.volume.replace('原理概论', '')} · ${item.data.title}`}
            </a>
          ))}
        </div>
      </nav>
    </aside>

    <div class="min-w-0">
      <article class="reading-article border border-gold-deep/20 bg-white/78 px-5 py-7 shadow-sm sm:px-8 lg:px-12">
        <div class="mb-8 flex flex-wrap gap-2">
          {entry.data.keywords.map((keyword) => (
            <span class="border border-gold-deep/25 bg-ivory px-2.5 py-1 text-xs text-gold-deep">{keyword}</span>
          ))}
        </div>
        <div class="academic-prose prose prose-lg max-w-none">
          <Content />
        </div>
      </article>

      <nav class="chapter-nav mt-6 grid gap-3 sm:grid-cols-2" aria-label="章节导航">
        {previous ? (
          <a class="border border-gold-deep/20 bg-white/70 p-4 text-sm text-ink/74 hover:border-gold-deep/45" href={withBase(`/book/${previous.slug}/`)}>
            <span class="block text-xs text-gold-deep">上一章</span>
            <span class="mt-1 block font-serif text-lg text-navy-850">{previous.data.title}</span>
          </a>
        ) : <div></div>}
        {next && (
          <a class="border border-gold-deep/20 bg-white/70 p-4 text-right text-sm text-ink/74 hover:border-gold-deep/45" href={withBase(`/book/${next.slug}/`)}>
            <span class="block text-xs text-gold-deep">下一章</span>
            <span class="mt-1 block font-serif text-lg text-navy-850">{next.data.title}</span>
          </a>
        )}
      </nav>
    </div>
  </div>
</div>

<script>
  const page = document.querySelector('[data-reading-page]');
  const progress = document.querySelector('[data-reading-progress]');
  const toggle = document.querySelector('[data-reading-mode]');
  const savedMode = localStorage.getItem('reading-mode');

  if (savedMode === 'dark') {
    page?.classList.add('is-dark');
    if (toggle) toggle.textContent = '浅色阅读';
  }

  const updateProgress = () => {
    if (!progress) return;
    const scrollTop = window.scrollY;
    const max = document.documentElement.scrollHeight - window.innerHeight;
    const percent = max > 0 ? Math.min(100, Math.max(0, (scrollTop / max) * 100)) : 0;
    progress.setAttribute('style', `width: ${percent}%`);
  };

  window.addEventListener('scroll', updateProgress, { passive: true });
  window.addEventListener('resize', updateProgress);
  updateProgress();

  toggle?.addEventListener('click', () => {
    page?.classList.toggle('is-dark');
    const dark = page?.classList.contains('is-dark');
    localStorage.setItem('reading-mode', dark ? 'dark' : 'light');
    toggle.textContent = dark ? '浅色阅读' : '深色阅读';
  });
</script>
