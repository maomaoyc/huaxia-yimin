---
import type { CollectionEntry } from 'astro:content';
import { getBookVolumeSlug, sortBookEntries } from '@/lib/book';
import { volumeTranslations } from '@/lib/i18n';
import { withBase } from '@/lib/paths';

interface Props {
  entries: CollectionEntry<'book'>[];
}

const sortedEntries = sortBookEntries(Astro.props.entries);
const prefaceEntry = sortedEntries.find((entry) => entry.slug === 'preface');
const afterwordEntry = sortedEntries.find((entry) => entry.slug === 'afterword');
const chapterEntries = sortedEntries.filter((entry) => entry.slug !== 'preface' && entry.slug !== 'afterword');
const entries = [
  ...(prefaceEntry ? [prefaceEntry] : []),
  ...(afterwordEntry ? [afterwordEntry] : []),
  ...chapterEntries
];
const featured = chapterEntries.slice(0, 18);
const firstReadable = entries[0];
const volumeGroups = ['volume-1', 'volume-2', 'volume-3'].map((slug) => ({
  slug,
  title: volumeTranslations[slug]?.zh.title ?? slug,
  entries: entries.filter((entry) => getBookVolumeSlug(entry) === slug)
})).filter((group) => group.entries.length);
const chapterLabel = (entry: CollectionEntry<'book'>) => {
  if (entry.data.chapterNumber === 0) return entry.data.title;
  if (entry.slug === 'afterword') return entry.data.title;
  return entry.data.title.replace(/^第[一二三四五六七八九十百〇零]+卷\s*[^·]+\s*·\s*/, '');
};
const readerText = (entry: CollectionEntry<'book'>) => entry.body
  .replace(/---[\s\S]*?---/, '')
  .replace(/^#+\s*/gm, '')
  .replace(/[`*_>]/g, '')
  .trim()
  .slice(0, 9000);
---

<section class="bg-ivory text-ink" id="reading-map">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="font-latin text-xs uppercase tracking-[0.26em] text-gold-deep">Reading Atlas</p>
        <h2 class="mt-3 font-serif text-3xl font-semibold text-navy-850">读书地图</h2>
      </div>
      <div class="inline-flex w-fit border border-gold-deep/25 bg-white/65 p-1 text-sm">
        <button class="map-tab bg-navy-850 px-4 py-2 text-ivory" type="button" data-map-tab="book">章节地图</button>
        <button class="map-tab px-4 py-2 text-gold-deep" type="button" data-map-tab="china">中国地图</button>
      </div>
    </div>

    <div class="mt-7 grid gap-6 lg:grid-cols-[1.08fr_0.92fr]">
      <div class="map-panel is-active border border-gold-deep/20 bg-white/68 p-4 sm:p-6" data-map-panel="book">
        <div class="reading-atlas" data-open-map>
          <div class="atlas-disc" aria-hidden="true">
            {featured.map((entry, index) => (
              <span class="atlas-node" style={`--i:${index};--n:${featured.length};`}>
                <span>{index + 1}</span>
              </span>
            ))}
          </div>
          <div class="atlas-center">
            <p class="font-serif text-2xl text-navy-850">全书逻辑图</p>
            <p class="mt-2 text-sm leading-6 text-ink/68">点击地图放大，并从章节索引进入阅读。</p>
          </div>
        </div>
      </div>

      <div class="map-panel hidden border border-gold-deep/20 bg-white/68 p-4 sm:p-6" data-map-panel="china">
        <div class="relative min-h-[26rem] overflow-hidden bg-[#efe5cb]">
          <svg class="absolute inset-0 h-full w-full" viewBox="0 0 720 520" role="img" aria-label="中国历史脉络示意图">
            <defs>
              <linearGradient id="chinaLand" x1="0" x2="1">
                <stop offset="0" stop-color="#d8c38c" />
                <stop offset="1" stop-color="#9fb58f" />
              </linearGradient>
            </defs>
            <path d="M162 164 248 96l119 16 91 55 94-2 69 72-31 81 35 72-78 55-102-19-90 45-105-26-69-78-74-17-33-86 56-48z" fill="url(#chinaLand)" stroke="#8a6b35" stroke-width="3" />
            <path d="M186 201c57-6 96 8 138 33 65 39 113 21 174 57 34 20 54 48 88 58" fill="none" stroke="#487c91" stroke-width="5" opacity=".52" />
            <path d="M292 147c24 72 14 151-34 234" fill="none" stroke="#487c91" stroke-width="3" opacity=".45" />
            <g fill="#102035" font-size="20" font-family="Noto Serif SC, Songti SC, serif">
              <text x="270" y="155">华夏文明</text>
              <text x="244" y="257">王朝演变</text>
              <text x="393" y="324">近代变局</text>
              <text x="300" y="405">正常化命题</text>
            </g>
          </svg>
        </div>
      </div>

      <div class="border border-gold-deep/20 bg-white/68 p-5">
        <h3 class="font-serif text-2xl font-semibold text-navy-850">章节索引</h3>
        <div class="mt-4 grid max-h-[26rem] gap-2 overflow-y-auto pr-2 text-sm">
          {entries.map((entry) => (
            <a class="border border-gold-deep/15 bg-ivory px-3 py-2 text-ink/74 transition hover:border-gold-deep/45 hover:text-gold-deep" href={withBase(`/book/${entry.slug}/`)}>
              {chapterLabel(entry)}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <dialog class="map-dialog h-[min(88vh,78rem)] w-[min(96vw,88rem)] overflow-hidden border border-gold-deep/35 bg-ivory p-0 text-ink shadow-soft" data-map-dialog>
    <div class="flex items-center justify-between border-b border-gold-deep/20 px-4 py-3">
      <h3 class="font-serif text-2xl text-navy-850">章节读书地图</h3>
      <button class="border border-gold-deep/35 px-3 py-1.5 text-sm text-gold-deep" type="button" data-close-map>关闭</button>
    </div>
    <div class="atlas-dialog-body h-[calc(100%-3.75rem)] overflow-hidden p-4" data-atlas-dialog-body>
      <div class="atlas-left-pane min-h-0 overflow-hidden" data-atlas-left-pane>
        <div class="reading-atlas large min-h-0" data-atlas-visual-pane>
          <div class="atlas-disc" aria-hidden="true">
            {featured.map((entry, index) => (
              <button
                type="button"
                class="atlas-node"
                style={`--i:${index};--n:${featured.length};`}
                data-reader-button
                data-reader-title={chapterLabel(entry)}
                data-reader-volume={entry.data.volume}
                data-reader-body={readerText(entry)}
              >
                <span>{index + 1}</span>
              </button>
            ))}
          </div>
          <div class="atlas-center">
            <p class="font-serif text-2xl text-navy-850">全书逻辑图</p>
            <p class="mt-2 text-sm text-ink/68">选择章节，在右侧小窗阅读。</p>
          </div>
        </div>
        <div class="atlas-resizer-y" title="拖动调整上下区域，双击恢复" data-atlas-resizer-y></div>
        <div class="atlas-toc overflow-hidden border border-gold-deep/20 bg-white/72 p-3">
          <div class="mb-2 flex items-center justify-between gap-3 border-b border-gold-deep/15 pb-2">
            <h4 class="font-serif text-lg text-navy-850">章节目录</h4>
          </div>
          <div class="atlas-toc-list grid gap-0.5 overflow-y-auto pr-1 text-[0.8rem] leading-6">
          {prefaceEntry && (
            <button
              type="button"
              class="truncate border-b border-gold-deep/12 px-2 py-1 text-left text-ink/76 transition hover:bg-ivory hover:text-gold-deep"
              title={chapterLabel(prefaceEntry)}
              data-reader-button
              data-reader-title={chapterLabel(prefaceEntry)}
              data-reader-volume={prefaceEntry.data.volume}
              data-reader-body={readerText(prefaceEntry)}
            >
              {chapterLabel(prefaceEntry)}
            </button>
          )}
          {afterwordEntry && (
            <button
              type="button"
              class="truncate border-b border-gold-deep/12 px-2 py-1 text-left text-ink/76 transition hover:bg-ivory hover:text-gold-deep"
              title={chapterLabel(afterwordEntry)}
              data-reader-button
              data-reader-title={chapterLabel(afterwordEntry)}
              data-reader-volume={afterwordEntry.data.volume}
              data-reader-body={readerText(afterwordEntry)}
            >
              {chapterLabel(afterwordEntry)}
            </button>
          )}
          {volumeGroups.map((group) => (
            <div class="grid gap-1">
              <p class="truncate px-2 pt-1 font-serif text-[0.76rem] font-semibold text-gold-deep" title={group.title}>{group.title}</p>
              {group.entries.map((entry) => (
                <button
                  type="button"
                  class="truncate border-b border-gold-deep/12 px-2 py-1 text-left text-ink/76 transition hover:bg-ivory hover:text-gold-deep"
                  title={chapterLabel(entry)}
                  data-reader-button
                  data-reader-title={chapterLabel(entry)}
                  data-reader-volume={entry.data.volume}
                  data-reader-body={readerText(entry)}
                >
                  {chapterLabel(entry)}
                </button>
              ))}
            </div>
          ))}
          </div>
        </div>
      </div>
      <div class="atlas-resizer-x" title="拖动调整左右区域，双击恢复" data-atlas-resizer-x></div>
      <div class="grid min-h-0 overflow-hidden" data-atlas-reader-pane>
        <div class="mini-reader min-h-0 overflow-hidden border border-gold-deep/20 bg-white/82">
          <div class="border-b border-gold-deep/15 px-4 py-2.5">
            <p class="text-[0.68rem] tracking-[0.22em] text-gold-deep" data-reader-volume-output>{firstReadable?.data.volume}</p>
            <h4 class="mt-1 font-serif text-lg text-navy-850" data-reader-title-output>{firstReadable ? chapterLabel(firstReadable) : '前言'}</h4>
          </div>
          <div class="mini-reader-body whitespace-pre-line px-4 py-3 font-serif text-[0.92rem] leading-[1.72] text-ink/84" data-reader-body-output>{firstReadable ? readerText(firstReadable) : ''}</div>
        </div>
      </div>
    </div>
  </dialog>
</section>

<script>
  document.querySelectorAll('[data-map-tab]').forEach((button) => {
    button.addEventListener('click', () => {
      const target = button instanceof HTMLElement ? button.dataset.mapTab : '';
      document.querySelectorAll('[data-map-tab]').forEach((tab) => {
        const active = tab instanceof HTMLElement && tab.dataset.mapTab === target;
        tab.classList.toggle('bg-navy-850', active);
        tab.classList.toggle('text-ivory', active);
        tab.classList.toggle('text-gold-deep', !active);
      });
      document.querySelectorAll('[data-map-panel]').forEach((panel) => {
        const active = panel instanceof HTMLElement && panel.dataset.mapPanel === target;
        panel.classList.toggle('hidden', !active);
        panel.classList.toggle('is-active', active);
      });
    });
  });

  const dialog = document.querySelector('[data-map-dialog]');
  const readerTitle = document.querySelector('[data-reader-title-output]');
  const readerVolume = document.querySelector('[data-reader-volume-output]');
  const readerBody = document.querySelector('[data-reader-body-output]');
  document.querySelectorAll('[data-reader-button]').forEach((button) => {
    button.addEventListener('click', (event) => {
      event.preventDefault();
      if (!(button instanceof HTMLElement)) return;
      const convert = localStorage.getItem('han-script') === 'traditional' && window.toTraditionalText
        ? window.toTraditionalText
        : ((value) => value);
      if (readerTitle) readerTitle.textContent = convert(button.dataset.readerTitle || '');
      if (readerVolume) readerVolume.textContent = convert(button.dataset.readerVolume || '');
      if (readerBody) readerBody.textContent = convert(button.dataset.readerBody || '');
    });
  });
  document.querySelector('[data-open-map]')?.addEventListener('click', (event) => {
    if (dialog instanceof HTMLDialogElement) dialog.showModal();
  });
  document.querySelector('[data-close-map]')?.addEventListener('click', () => {
    if (dialog instanceof HTMLDialogElement) dialog.close();
  });

  const atlasBody = document.querySelector('[data-atlas-dialog-body]');
  const leftPane = document.querySelector('[data-atlas-left-pane]');
  const resizerX = document.querySelector('[data-atlas-resizer-x]');
  const resizerY = document.querySelector('[data-atlas-resizer-y]');
  const applyAtlasSizes = () => {
    if (!(atlasBody instanceof HTMLElement)) return;
    const left = localStorage.getItem('huaxia-atlas-left') || '40';
    const top = localStorage.getItem('huaxia-atlas-top') || '57';
    atlasBody.style.setProperty('--atlas-left', `${left}%`);
    atlasBody.style.setProperty('--atlas-top', `${top}%`);
  };
  const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
  const startDrag = (event, axis) => {
    event.preventDefault();
    const move = (moveEvent) => {
      if (!(atlasBody instanceof HTMLElement)) return;
      const rect = atlasBody.getBoundingClientRect();
      if (axis === 'x') {
        const percent = clamp(((moveEvent.clientX - rect.left) / rect.width) * 100, 5, 82);
        localStorage.setItem('huaxia-atlas-left', percent.toFixed(1));
      } else if (leftPane instanceof HTMLElement) {
        const paneRect = leftPane.getBoundingClientRect();
        const percent = clamp(((moveEvent.clientY - paneRect.top) / paneRect.height) * 100, 5, 86);
        localStorage.setItem('huaxia-atlas-top', percent.toFixed(1));
      }
      applyAtlasSizes();
    };
    const end = () => {
      window.removeEventListener('pointermove', move);
      window.removeEventListener('pointerup', end);
    };
    window.addEventListener('pointermove', move);
    window.addEventListener('pointerup', end);
  };
  if (resizerX instanceof HTMLElement) {
    resizerX.addEventListener('pointerdown', (event) => startDrag(event, 'x'));
    resizerX.addEventListener('dblclick', () => {
      localStorage.setItem('huaxia-atlas-left', '40');
      applyAtlasSizes();
    });
  }
  if (resizerY instanceof HTMLElement) {
    resizerY.addEventListener('pointerdown', (event) => startDrag(event, 'y'));
    resizerY.addEventListener('dblclick', () => {
      localStorage.setItem('huaxia-atlas-top', '57');
      applyAtlasSizes();
    });
  }
  applyAtlasSizes();
</script>
