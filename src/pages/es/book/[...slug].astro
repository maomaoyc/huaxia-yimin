---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ReadingLayout from '@/components/reading/ReadingLayout.astro';
import { sortBookEntries } from '@/lib/book';

const locale = 'es';

export async function getStaticPaths() {
  const entries = await getCollection('book');
  return entries.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const { entry } = Astro.props;
const entries = sortBookEntries(await getCollection('book'));
const index = entries.findIndex((item) => item.slug === entry.slug);
const previous = index > 0 ? entries[index - 1] : undefined;
const next = index >= 0 && index < entries.length - 1 ? entries[index + 1] : undefined;
---

<BaseLayout title={`${entry.data.title} | Lectura`} description={entry.data.summary} locale={locale}>
  <ReadingLayout entry={entry} entries={entries} previous={previous} next={next} locale={locale} />
</BaseLayout>
