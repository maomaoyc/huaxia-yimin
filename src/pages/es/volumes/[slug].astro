---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import ContentShell from '@/components/ContentShell.astro';
import ChapterCards from '@/components/ChapterCards.astro';
import { getBookVolumeSlug, sortBookEntries } from '@/lib/book';
import { localizeKeywords, volumeTranslations } from '@/lib/i18n';

const locale = 'es';

export async function getStaticPaths() {
  const volumes = await getCollection('volumes');
  return volumes.map((volume) => ({ params: { slug: volume.slug }, props: { volume } }));
}

const { volume } = Astro.props;
const localizedVolume = volumeTranslations[volume.slug]?.[locale] ?? {
  title: volume.data.title,
  shortTitle: volume.data.shortTitle,
  description: volume.data.description
};
const bookEntries = sortBookEntries(await getCollection('book'))
  .filter((entry) => getBookVolumeSlug(entry) === volume.slug)
  .map((entry) => ({
    title: `Capítulo ${entry.data.chapterNumber}: texto chino`,
    summary: `Guía breve del capítulo ${entry.data.chapterNumber}. La traducción completa al español podrá incorporarse después sin cambiar la ruta.`,
    concepts: localizeKeywords(entry.data.keywords, locale),
    link: `/book/${entry.slug}/`
  }));
---

<BaseLayout title={`${localizedVolume.shortTitle} | Español`} description={localizedVolume.description} locale={locale}>
  <PageHero title={localizedVolume.title} eyebrow="Guía en español" description={localizedVolume.description} locale={locale} />
  <ContentShell>
    <p>Esta página refleja la estructura del volumen chino. Los títulos de capítulos y las páginas de lectura completa permanecen en chino para conservar precisión textual.</p>
    <div class="not-prose mt-10">
      <ChapterCards chapters={bookEntries} locale={locale} />
    </div>
  </ContentShell>
</BaseLayout>
