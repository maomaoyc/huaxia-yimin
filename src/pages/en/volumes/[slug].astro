---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import ContentShell from '@/components/ContentShell.astro';
import ChapterCards from '@/components/ChapterCards.astro';
import { getBookVolumeSlug, sortBookEntries } from '@/lib/book';
import { localizeKeywords, volumeTranslations } from '@/lib/i18n';

const locale = 'en';

export async function getStaticPaths() {
  const volumes = await getCollection('volumes');
  return volumes.map((volume) => ({ params: { slug: volume.slug }, props: { volume } }));
}

const { volume } = Astro.props;
const localizedVolume = volumeTranslations[volume.slug]?.[locale] ?? {
  title: volume.data.title,
  shortTitle: volume.data.shortTitle,
  description: volume.data.description
};
const bookEntries = sortBookEntries(await getCollection('book'))
  .filter((entry) => getBookVolumeSlug(entry) === volume.slug)
  .map((entry) => ({
    title: `Chapter ${entry.data.chapterNumber}: Chinese Text`,
    summary: `Concise guide for chapter ${entry.data.chapterNumber}. A full English translation can be added later while the chapter route remains stable.`,
    concepts: localizeKeywords(entry.data.keywords, locale),
    link: `/book/${entry.slug}/`
  }));
---

<BaseLayout title={`${localizedVolume.shortTitle} | English`} description={localizedVolume.description} locale={locale}>
  <PageHero title={localizedVolume.title} eyebrow="English Guide" description={localizedVolume.description} locale={locale} />
  <ContentShell>
    <p>This page mirrors the Chinese volume structure. Chapter titles and full reading pages remain in Chinese for textual accuracy.</p>
    <div class="not-prose mt-10">
      <ChapterCards chapters={bookEntries} locale={locale} />
    </div>
  </ContentShell>
</BaseLayout>
