---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.astro';
import ContentShell from '@/components/ContentShell.astro';
import Timeline from '@/components/Timeline.astro';
import DownloadCenter from '@/components/DownloadCenter.astro';
import PdfCallout from '@/components/PdfCallout.astro';
import SubmissionForms from '@/components/SubmissionForms.astro';
import BookTextEmbed from '@/components/BookTextEmbed.astro';
import AfterwordPanels from '@/components/AfterwordPanels.astro';

export async function getStaticPaths() {
  const hiddenPages = new Set(['structure', 'diagrams', 'author-submissions']);
  const pages = await getCollection('pages');
  return pages
    .filter((page) => page.slug !== 'home' && !hiddenPages.has(page.slug))
    .map((page) => ({
      params: { slug: page.slug },
      props: { page }
    }));
}

const { page } = Astro.props;
const bookEntries = await getCollection('book');
const preface = bookEntries.find((entry) => entry.slug === 'preface');
const afterword = bookEntries.find((entry) => entry.slug === 'afterword');
const { Content } = await page.render();
---

<BaseLayout title={`${page.data.title} | 华夏义民起义、变革、正常化之法理`} description={page.data.description}>
  {page.slug !== 'reader-feedback' && <PageHero title={page.data.title} eyebrow={page.data.eyebrow} description={page.data.description} />}
  {page.slug !== 'letter' && page.slug !== 'reader-feedback' && (
    <ContentShell>
      <Content />
    </ContentShell>
  )}
  {page.slug === 'introduction' && <PdfCallout title="下载完整 PDF" text="本书 PDF 将通过固定链接提供，适合离线阅读、引用与打印。" />}
  {page.slug === 'timeline' && <Timeline />}
  {page.slug === 'downloads' && <DownloadCenter />}
  {page.slug === 'arguments' && preface && <BookTextEmbed entry={preface} title="原书前言" />}
  {page.slug === 'letter' && <AfterwordPanels entry={afterword} />}
  {page.slug === 'author-submissions' && <SubmissionForms mode="author" />}
  {page.slug === 'reader-feedback' && <SubmissionForms mode="reader" />}
</BaseLayout>
