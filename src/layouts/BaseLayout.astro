---
import { getCollection } from 'astro:content';
import { withBase } from '@/lib/paths';
import { localizedPath, navTranslations, siteTitle, uiText, type Locale } from '@/lib/i18n';
import LanguageSwitch from '@/components/LanguageSwitch.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  locale?: Locale;
}

const { title, description, locale = 'zh' } = Astro.props;
const pages = await getCollection('pages');
const volumes = await getCollection('volumes');
const hiddenPageSlugs = new Set(['structure', 'diagrams', 'author-submissions']);

const navItems = [
  ...pages.filter((page) => !hiddenPageSlugs.has(page.slug)).map((page) => ({
    label: navTranslations[page.slug]?.[locale] ?? page.data.navLabel ?? page.data.title,
    href: withBase(localizedPath(locale, page.slug === 'home' ? '/' : `/${page.slug}/`)),
    order: page.data.order
  })),
  ...volumes.map((volume) => ({
    label: navTranslations[volume.slug]?.[locale] ?? volume.data.shortTitle,
    href: withBase(localizedPath(locale, `/volumes/${volume.slug}/`)),
    order: volume.data.order
  }))
].sort((a, b) => a.order - b.order);
const navLabel = {
  zh: '主导航',
  en: 'Main navigation',
  es: 'Navegación principal'
};
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-Hans' : locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <title>{title}</title>
  </head>
  <body>
    <header class="border-b border-gold-muted/20 bg-navy-950/92 backdrop-blur">
      <a class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-ivory focus:px-4 focus:py-2 focus:text-navy-950" href="#content">{locale === 'zh' ? '跳至正文' : locale === 'en' ? 'Skip to content' : 'Saltar al contenido'}</a>
      <div class="mx-auto flex max-w-7xl flex-col gap-5 px-4 py-5 sm:px-6 lg:px-8">
        <div class="flex items-start justify-between gap-5">
          <a href={withBase(localizedPath(locale, '/'))} class="group max-w-[18rem] sm:max-w-lg">
            <p class="font-serif text-lg font-semibold leading-snug text-ivory sm:text-2xl">{siteTitle[locale]}</p>
            <p class="mt-1 text-xs uppercase tracking-[0.28em] text-gold-pale/80">Academic Book Project</p>
          </a>
          <div class="flex shrink-0 items-center gap-2">
            <LanguageSwitch locale={locale} />
            <a href={withBase('/downloads/huaxia-yimin.pdf')} download class="border border-gold-muted/50 px-3 py-2 text-sm text-gold-pale transition hover:bg-gold-muted hover:text-navy-950">{uiText.downloadPdf[locale]}</a>
          </div>
        </div>
        <nav aria-label={navLabel[locale]} class="-mx-2 flex gap-1 overflow-x-auto pb-1">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="whitespace-nowrap px-2.5 py-2 text-sm text-ivory/76 transition hover:text-gold-pale"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="bg-navy-950 text-ivory">
      <div class="mx-auto grid max-w-7xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_0.7fr] lg:px-8">
        <div>
          <p class="font-serif text-xl">{siteTitle[locale]}</p>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-ivory/68">{uiText.footerNote[locale]}</p>
        </div>
        <div class="text-sm leading-7 text-ivory/68">
          <p>Static build: Astro + Tailwind CSS</p>
          <p>Deploy targets: Cloudflare Pages / Vercel / Netlify</p>
          <p>{uiText.contact[locale]}：<a class="text-gold-pale underline decoration-gold-muted/40" href="mailto:yc114de@gmail.com">yc114de@gmail.com</a></p>
          <p><a class="text-gold-pale underline decoration-gold-muted/40" href={withBase(localizedPath(locale, '/letter/'))}>{navTranslations.letter[locale]}</a> · <a class="text-gold-pale underline decoration-gold-muted/40" href={withBase(localizedPath(locale, '/reader-feedback/'))}>{navTranslations['reader-feedback'][locale]}</a></p>
        </div>
      </div>
    </footer>
  </body>
</html>
